---
import { Image } from "astro:assets";
import foto1 from "../../public/30221.jpg";
import foto2 from "../../public/30222.jpg";
import foto3 from "../../public/30223.jpg";
import foto4 from "../../public/30224.jpg";
import foto5 from "../../public/30225.jpg";
import foto6 from "../../public/30226.jpg";
import foto7 from "../../public/30227.jpg";
const fotos = [foto1, foto2, foto3, foto4, foto5, foto6, foto7];

import { strings } from "../data/strings";
const { hero, letterModal } = strings;
---

<div
  class="hero bg-linear-to-tr from-primary/20 to-secondary/20 rounded-2xl py-8 px-4 text-center"
>
  <div class="hero-content w-full p-0">
    <div class="max-w-md mx-auto flex flex-col items-center w-full">
      <div class="avatar mb-6 w-full">
        <div
          class="w-full aspect-square rounded-full ring ring-primary ring-offset-base-100 ring-offset-2 shadow-2xl overflow-hidden relative"
        >
          <Image
            id="foto-avatar"
            src={fotos[0]}
            width={600}
            height={600}
            alt="Fotos de Alison"
            class="w-full h-full object-cover transition-opacity duration-500 opacity-100"
          />
        </div>
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight">{hero.title}</h1>
      <p
        class="py-4 text-base-content/80 text-sm leading-relaxed"
        set:html={hero.welcomeMessage}
      />

      <button
        class="btn btn-primary btn-md shadow-2xl rounded-full gap-2 border-2 border-white px-8 w-full max-w-xs"
        onclick="document.getElementById('modal-carta').showModal()"
      >
        {hero.buttonText}
      </button>
    </div>
  </div>
</div>

<dialog id="modal-carta" class="modal modal-bottom sm:modal-middle">
  <div class="modal-box p-6 relative">
    <form method="dialog">
      <button
        class="btn btn-sm btn-circle btn-ghost absolute right-4 top-4 z-20"
        >✕</button
      >
    </form>

    <div
      class="flex justify-between items-end border-b border-base-300 pb-3 mb-4 pt-4"
    >
      <div class="flex flex-col text-left gap-0.5">
        <span
          class="text-xs font-semibold text-base-content/80 uppercase tracking-wider"
        >
          {letterModal.from}
        </span>
        <span
          class="text-xs font-semibold text-base-content/80 uppercase tracking-wider"
        >
          {letterModal.to}
        </span>
      </div>

      <div class="text-right">
        <span class="text-xs font-mono italic text-base-content/60">
          {letterModal.date}
        </span>
      </div>
    </div>

    <p
      class="py-2 text-sm leading-relaxed text-left text-base-content/90"
      set:html={letterModal.body}
    />

    <div class="modal-action mt-6 flex justify-center w-full">
      <form method="dialog" class="w-full flex justify-center">
        <button
          class="btn btn-primary btn-md shadow-2xl rounded-full gap-2 border-2 border-white px-8 w-full max-w-xs"
        >
          {letterModal.closeButton}
        </button>
      </form>
    </div>
  </div>
</dialog>

<script define:vars={{ fotos }}>
  const imgElement = document.getElementById("foto-avatar");
  let currentIndex = 0;

  if (imgElement && fotos && fotos.length > 0) {
    // Extraemos solo las rutas (strings) que entiende el navegador
    const srcList = fotos.map((f) => (typeof f === "object" ? f.src : f));

    setInterval(() => {
      // 1. Empezamos a desvanecer la foto actual
      imgElement.classList.remove("opacity-100");
      imgElement.classList.add("opacity-0");

      // 2. Esperamos 500ms a que termine de desaparecer por completo
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % srcList.length;
        imgElement.src = srcList[currentIndex];

        // 3. Añadimos un SEGUNDO retraso (por ejemplo, 400ms) con la imagen ya cambiada pero invisible
        setTimeout(() => {
          imgElement.classList.remove("opacity-0");
          imgElement.classList.add("opacity-100");
        }, 400); // <- Este es el tiempo que se queda totalmente en blanco/invisible
      }, 500);
    }, 4000);
  }
</script>
