---
import { strings } from "../data/strings";
const { fireworksButton } = strings;
---

<!-- Contenedor invisible para los fuegos artificiales (pantalla completa) -->
<div id="fireworks-container" class="fixed inset-0 pointer-events-none z-100">
</div>

<!-- Botón flotante estilo DaisyUI (fijo abajo a la derecha) -->
<div class="fixed bottom-0 left-1/2 -translate-x-1/2 z-101 w-max">
    <button
        id="fireworks-btn"
        class="btn btn-primary btn-md shadow-2xl rounded-full gap-2 border-2 border-white animate-bounce px-6"
    >
        {fireworksButton}
    </button>
</div>

<script>
    // Importamos la librería directamente en el script del lado del cliente de Astro
    import { Fireworks } from "fireworks-js";
    import { strings } from "../data/strings";
    const { fireworksPressedButton } = strings;

    document.addEventListener('click', (event) => {
        const target = event.target as HTMLButtonElement; 
        if (target && target.id === 'fireworks-btn') {
            if (target.disabled) return;

            const container = document.getElementById('fireworks-container');
            if (!container) return;
            
            target.disabled = true;
            const originalText = target.innerText;
            target.innerText = fireworksPressedButton;

            const fireworks = new Fireworks(container, {
                autoresize: true,
                opacity: 0.5,
                acceleration: 1.05,
                friction: 0.97,
                gravity: 1.5,
                particles: 50,
                traceLength: 3,
                traceSpeed: 10,
                explosion: 5,
                intensity: 30,
                flickering: 50,
                lineStyle: 'round',
                hue: {
                    min: 0,
                    max: 360
                },
                delay: {
                    min: 30,
                    max: 60
                },
                rocketsPoint: {
                    min: 50,
                    max: 50
                },
                lineWidth: {
                    explosion: {
                        min: 1,
                        max: 3
                    },
                    trace: {
                        min: 1,
                        max: 2
                    }
                },
                brightness: {
                    min: 50,
                    max: 80
                },
                decay: {
                    min: 0.015,
                    max: 0.03
                },
                mouse: {
                    click: false,
                    move: false,
                    max: 1
                },
                sound: {
                    enabled: true,
                    volume: { min: 2, max: 4 },
                    files: [
                        'https://fireworks.js.org/sounds/explosion0.mp3',
                        'https://fireworks.js.org/sounds/explosion1.mp3',
                        'https://fireworks.js.org/sounds/explosion2.mp3'
                    ]
                }
            });
            
            fireworks.start();
            
            // A los 12 segundos, iniciar la traca final super intensa
            setTimeout(() => {
                fireworks.updateOptions({
                    intensity: 100, // Mucha más intensidad
                    particles: 100, // Más partículas por explosión
                });
            }, 12000); // 12 segundos
            
            // Duren 20 segundos en total
            setTimeout(() => {
                // Detenemos nuevos lanzamientos pero mantenemos explosiones para que terminen
                fireworks.updateOptions({
                    intensity: 0 // Solo detenemos nuevos cohetes, los que están siguen explotando
                });

                // Esperamos un par de segundos más para que desaparezcan del todo antes de parar el motor
                setTimeout(() => {
                    fireworks.stop();
                    target.disabled = false;
                    target.innerText = originalText;
                    // Limpiamos cualquier canvas anterior para que funcione siempre
                    container.innerHTML = '';
                }, 3000); // 3 segundos de "vaciado"
            }, 20000); // 20 segundos de duración activa
        }
    });
</script>
